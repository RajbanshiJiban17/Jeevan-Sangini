# Local Ollama (CPU — small model)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT=180

# Cloud fallback (optional on laptop)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# auto | ollama | gemini
LLM_BACKEND=auto

# RAG (set ENABLE_RAG=yes on cloud only if you added heavy deps)
ENABLE_RAG=yes
DATA_DIR=data
