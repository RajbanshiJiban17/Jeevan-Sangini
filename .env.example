# ========== OPTION A: No Ollama (internet, ~0 GB download) ==========
LLM_BACKEND=gemini
GOOGLE_API_KEY=your-key-from-aistudio.google.com
GEMINI_MODEL=gemini-1.5-flash

# ========== OPTION B: Small Ollama (CPU, ~1.6 GB) ==========
# LLM_BACKEND=auto
# OLLAMA_MODEL=gemma2:2b
# OLLAMA_HOST=http://localhost:11434

# Even smaller (~1.3 GB):
# OLLAMA_MODEL=llama3.2:1b

# Bigger / better but ~7+ GB (slow internet):
# OLLAMA_MODEL=gemma4:e2b

OLLAMA_TIMEOUT=300
ENABLE_RAG=no
DATA_DIR=data
